@startuml

title Use Case - Wali Murid (Orang Tua Santri) PPTQ Ibnu Juraimi

left to right direction
skinparam packageStyle rectangle

actor "Wali Murid" as Wali

rectangle "Sistem Informasi PPTQ Ibnu Juraimi" {

    usecase "Login" as UC_Login
    usecase "Logout" as UC_Logout
    usecase "Edit Profil" as UC_EditProfile

    usecase "Dashboard Wali Murid\n(Summary per Anak)" as UC_Dashboard

    usecase "Laporan Mingguan" as UC_LaporanMingguan

    usecase "Riwayat Kegiatan\n(Kehadiran Santri)" as UC_RiwayatKegiatan

    usecase "Filter Santri\n& Periode" as UC_Filter
}

Wali --> UC_Login
Wali --> UC_Logout
Wali --> UC_EditProfile

Wali --> UC_Dashboard
Wali --> UC_LaporanMingguan
Wali --> UC_RiwayatKegiatan

UC_LaporanMingguan ..> UC_Filter : <<extend>>
UC_RiwayatKegiatan ..> UC_Filter : <<extend>>

@enduml
