@startuml

title Sequence Diagram - Ustadz: Presensi Santri (Setelah Presensi Kegiatan)

actor Ustadz
participant "Browser" as Browser
participant "Route" as Route
participant "PresensiSantriController" as Ctrl
participant "Database" as DB

Ustadz -> Browser : Lihat detail presensi kegiatan
Ustadz -> Browser : Klik "Isi Presensi Santri"
Browser -> Route : GET /ustadz/presensi-santri/{presensi}/create
Route -> Ctrl : create(presensiKegiatan)

Ctrl -> DB : Query presensi_kegiatan find(id)
DB --> Ctrl : Data presensi (tingkatan, kelas)
Ctrl -> DB : Query santri_binaan WHERE tingkatan & kelas match
DB --> Ctrl : List santri binaan
Ctrl --> Browser : Render form checklist santri

Ustadz -> Browser : Pilih status tiap santri\n(Hadir/Izin/Sakit/Alpha)
Ustadz -> Browser : Submit
Browser -> Route : POST /ustadz/presensi-santri/{presensi}
Route -> Ctrl : store(request, presensiKegiatan)

Ctrl -> DB : BEGIN TRANSACTION
loop Untuk setiap santri
    Ctrl -> DB : INSERT presensi_santri\n(presensi_kegiatan_id, santri_id, status)
end
Ctrl -> DB : COMMIT

DB --> Ctrl : Sukses
Ctrl --> Browser : Redirect + flash message
Browser --> Ustadz : Tampilkan ringkasan presensi

@enduml
